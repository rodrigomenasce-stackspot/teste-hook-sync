{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "node-app",
  "sourceRoot": "apps/node-app/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "apps/node-app",
        "command": "npm run build"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/node-app",
        "command": "npm start"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/node-app",
        "command": "npm test"
      }
    }
  }
}
