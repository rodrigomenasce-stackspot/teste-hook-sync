{
  "name": "empty-test-repo",
  "version": "0.1.0",
  "private": true,
  "description": "Simple Node.js app used to test NX builds.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "build": "esbuild src/index.js --bundle --platform=node --target=node20 --outfile=dist/index.js",
    "start:dist": "node dist/index.js",
    "test": "node --test \"test/**/*.test.js\""
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "nx": "22.7.2"
  },
  "nx": {}
}